{
  "name": "@shopee-research/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node ./scripts/copy-pages-function.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "deploy:pages": "pnpm build && wrangler pages deploy dist --project-name shopee-product-research-web --branch main --commit-dirty=true --skip-caching"
  },
  "dependencies": {
    "@shopee-research/core": "workspace:*",
    "@shopee-research/shared": "workspace:*",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-router": "^1.139.3",
    "@vitejs/plugin-react": "^5.1.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1"
  }
}
